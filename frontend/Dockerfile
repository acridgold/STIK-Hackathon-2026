FROM node:18-alpine

WORKDIR /app

# 1. Копируем файлы зависимостей из КОРНЯ (контекст сборки .)
COPY package*.json ./

# 2. Устанавливаем зависимости
RUN npm ci

# 3. Копируем содержимое папки frontend в рабочую директорию /app
COPY frontend/ .

# 4. Пробрасываем порт Vite
EXPOSE 5173

# 5. Запуск. Используем npx, чтобы точно найти vite в node_modules
# Флаг --host 0.0.0.0 обязателен, чтобы контейнер отвечал на запросы извне
CMD ["npx", "vite", "--host", "0.0.0.0"]